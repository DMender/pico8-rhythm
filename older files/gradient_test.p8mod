pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
tick = 0
frame = 0
function _init()
	pal({[0]=0,5,8,7,128,132,4,143,129,1,140,6,131,3,139,15},1)
	poke(0x5f5f,0x3f)
	pal({[0]=136,133,133,12,12,136,134,134,14,14,14,133,14,133,14,12},2)
end
function _draw()
	tick += 1
	if tick%2 == 0 then
		frame += 1
		if frame == 9 then
			frame = 0
		end
	end
--adjustable gradient
if frame == 0 then
	memset(0x5f7b,0b00000000,1)
	memset(0x5f7c,0b00000000,1)
	memset(0x5f7d,0b11111111,1)
elseif frame == 1 then
	memset(0x5f7b,0b00000001,1)
	memset(0x5f7c,0b00000001,1)
	memset(0x5f7d,0b11111111,1)
elseif frame == 2 then
	memset(0x5f7b,0b00000011,1)
	memset(0x5f7c,0b00000011,1)
	memset(0x5f7d,0b11111111,1)
elseif frame == 3 then
	memset(0x5f7b,0b00000111,1)
	memset(0x5f7c,0b00000111,1)
	memset(0x5f7d,0b11111111,1)
elseif frame == 4 then
	memset(0x5f7b,0b00001111,1)
	memset(0x5f7c,0b00001111,1)
	memset(0x5f7d,0b11111111,1)
elseif frame == 5 then
	memset(0x5f7b,0b00011111,1)
	memset(0x5f7c,0b00011111,1)
	memset(0x5f7d,0b11111111,1)
elseif frame == 6 then
	memset(0x5f7b,0b00111111,1)
	memset(0x5f7c,0b00111111,1)
	memset(0x5f7d,0b11111111,1)
elseif frame == 7 then
	memset(0x5f7b,0b01111111,1)
	memset(0x5f7c,0b01111111,1)
	memset(0x5f7d,0b11111111,1)
elseif frame == 8 then
	memset(0x5f7b,0b11111111,1)
	memset(0x5f7c,0b11111111,1)
	memset(0x5f7d,0b11111111,1)
end
-- set gradient
	memset(0x5f72,0b11110000,1)
	memset(0x5f77,0b11110000,1)
	memset(0x5f7f,0b00001111,1)
	cls()
	line(0,0,0,128,15)
	line(1,0,1,128,15)
	line(2,0,2,128,15)
	line(3,0,3,128,15)
	line(4,0,4,128,15)
	line(5,0,5,128,15)
	line(6,0,6,128,15)
	print("0",8,0*8)
	print("1",8,1*8)
	print("2: 2 pulls bottom 4 pixels from below ",8,2*8)
	print("3",8,3*8)
	print("4",8,4*8)
	print("5",8,5*8)
	print("6",8,6*8)
	print("7: 7 pulls bottom 4 pixels from below ",8,7*8)
	print("8",8,8*8)
	print("9",8,9*8)
	print("a",8,10*8)
	print("b: b pulls top 4 pixels from below ",8,11*8)
	print("c: c pulls top 4 pixels from below ",8,12*8)
	print("d: d pulls bottom ALL pixels from below ",8,13*8)
	print("e",8,14*8)
	print("f: f pulls top 4 pixels from 0",8,15*8)
end
